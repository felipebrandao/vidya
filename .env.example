# Banco de dados (Neon PostgreSQL)
DB_URL=jdbc:postgresql://<host>:5432/<database>?sslmode=require
DB_USERNAME=
DB_PASSWORD=

# JWT (gere uma chave aleatória de 256 bits, ex: openssl rand -hex 32)
JWT_SECRET=
JWT_EXPIRATION=86400000

# Sankhya ERP
SANKHYA_BASE_URL=http://<host>:<port>
SANKHYA_USERNAME=
SANKHYA_PASSWORD=

